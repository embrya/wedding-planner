rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isPlannerFor(weddingId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == "planner"
        && userDoc().data.weddingId == weddingId;
    }

    function isMemberFor(weddingId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.weddingId == weddingId;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && (
          request.auth.uid == userId
          || isPlannerFor(request.resource.data.weddingId)
        );
      allow update, delete: if false;
    }

    match /weddings/{weddingId} {
      allow create: if signedIn()
        && request.resource.data.plannerUid == request.auth.uid;
      allow read: if isMemberFor(weddingId)
        || (signedIn() && resource.data.plannerUid == request.auth.uid);
      allow update: if isPlannerFor(weddingId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isMemberFor(weddingId);
        allow create, update: if isPlannerFor(weddingId)
          || (signedIn() && request.auth.uid == memberId);
        allow delete: if isPlannerFor(weddingId);
      }

      match /dayNotes/{noteId} {
        allow read: if isMemberFor(weddingId);
        allow write: if isPlannerFor(weddingId);
      }

      match /weekNotes/{noteId} {
        allow read: if isMemberFor(weddingId);
        allow write: if isPlannerFor(weddingId);
      }
    }
  }
}
